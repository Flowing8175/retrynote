# Database
DATABASE_URL=postgresql+asyncpg://quiz:quiz@localhost:5432/quizmanager
DATABASE_URL_SYNC=postgresql://quiz:quiz@localhost:5432/quizmanager

# Redis
REDIS_URL=redis://:your-redis-password@localhost:6379/0
REDIS_PASSWORD=your-redis-password

# JWT
JWT_SECRET_KEY=change-me-to-a-secure-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
ADMIN_SESSION_EXPIRE_MINUTES=30

# Master password for admin verification (will be hashed on first use)
ADMIN_MASTER_PASSWORD=

# AI — OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_GENERATION_MODEL=gpt-4o
OPENAI_GRADING_MODEL=gpt-4o-mini
OPENAI_FALLBACK_GENERATION_MODEL=gpt-4o-mini
OPENAI_FALLBACK_GRADING_MODEL=gpt-3.5-turbo

# AI — Gemini (optional; leave GEMINI_API_KEY blank to disable)
GEMINI_API_KEY=
GEMINI_GENERATION_MODEL=gemini-2.0-flash
GEMINI_GRADING_MODEL=gemini-2.0-flash
GEMINI_FALLBACK_GENERATION_MODEL=gemini-1.5-flash
GEMINI_FALLBACK_GRADING_MODEL=gemini-1.5-flash

# Model tiers — provider is auto-detected from the model name prefix.
# Set each to any model string (OpenAI or Gemini); leave blank to omit that tier.
ECO_GENERATION_MODEL=gpt-5.4-nano
BALANCED_GENERATION_MODEL=gpt-5.4-mini
PERFORMANCE_GENERATION_MODEL=gemini-3-flash

# File storage
UPLOAD_DIR=./storage/uploads
MAX_UPLOAD_SIZE_MB=100
ALLOWED_FILE_TYPES=pdf,docx,pptx,txt,md,png,jpg,jpeg

# App
APP_ENV=development
APP_URL=http://localhost:5173
API_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:5173

# SMTP (for password reset)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# Job timeouts (seconds)
GENERATION_TIMEOUT=120
GRADING_TIMEOUT=60
OBJECTION_REVIEW_TIMEOUT=90
FILE_PROCESSING_TIMEOUT=300

# Rate limits
MAX_RETRY_COUNT=3
DAILY_QUIZ_GENERATION_LIMIT=50
DAILY_OCR_PAGE_LIMIT=100

# Paddle (결제)
PADDLE_API_KEY=
PADDLE_ENVIRONMENT=sandbox
PADDLE_WEBHOOK_SECRET=
# Subscription price IDs (Paddle Dashboard에서 생성)
PADDLE_LEARNER_LITE_MONTHLY_PRICE_ID=
PADDLE_LEARNER_LITE_QUARTERLY_PRICE_ID=
PADDLE_LEARNER_PRO_MONTHLY_PRICE_ID=
PADDLE_LEARNER_PRO_QUARTERLY_PRICE_ID=
# Credit pack price IDs
PADDLE_STORAGE_5GB_PRICE_ID=
PADDLE_STORAGE_20GB_PRICE_ID=
PADDLE_AI_CREDITS_100_PRICE_ID=
PADDLE_AI_CREDITS_500_PRICE_ID=
